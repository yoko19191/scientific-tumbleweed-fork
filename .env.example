# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                         环境变量配置 (.env)                                ║
# ║  复制本文件为 .env 并填入你的密钥。注释掉的变量为可选项，按需启用。          ║
# ╚══════════════════════════════════════════════════════════════════════════════╝


# ============================================================================
# 一、大模型 API 密钥（config.yaml 中的模型会引用这些变量）
# ============================================================================

# --- DeepSeek（默认模型，直连官方 API）---
DEEPSEEK_API_KEY=your-deepseek-api-key

# --- 月之暗面 / Kimi（直连官方 API）---
MOONSHOT_API_KEY=your-moonshot-api-key

# --- 以下模型通过 dmxapi.cn 中转，共用同一个 dmxapi 密钥 ---
# 在 https://www.dmxapi.cn 注册获取密钥，填入下面三个变量（可以是同一个值）
OPENAI_API_KEY=your-dmxapi-key
ANTHROPIC_API_KEY=your-dmxapi-key
GEMINI_API_KEY=your-dmxapi-key

# --- 火山引擎 / 豆包（如需启用，在 config.yaml 中取消注释对应模型）---
# VOLCENGINE_API_KEY=your-volcengine-api-key

# --- Novita AI（OpenAI 兼容，https://novita.ai）---
# NOVITA_API_KEY=your-novita-api-key

# --- MiniMax（OpenAI 兼容，https://platform.minimax.io）---
# MINIMAX_API_KEY=your-minimax-api-key


# ============================================================================
# 二、网络搜索与抓取 API 密钥
# ============================================================================
# Agent 执行"联网搜索"和"网页抓取"时需要以下密钥。

# --- Tavily（搜索引擎，https://tavily.com）---
TAVILY_API_KEY=your-tavily-api-key

# --- Jina AI（网页抓取，https://jina.ai）---
JINA_API_KEY=your-jina-api-key

# --- InfoQuest（国产搜索/抓取一体化）---
INFOQUEST_API_KEY=your-infoquest-api-key

# --- Firecrawl（备选网页抓取，https://firecrawl.dev）---
# FIRECRAWL_API_KEY=your-firecrawl-api-key


# ============================================================================
# 三、IM 渠道集成（飞书 / Slack / Telegram）
# ============================================================================
# 将 Agent 接入即时通讯平台，需在对应平台创建应用并获取凭证。

# --- 飞书 / Lark ---
# FEISHU_APP_ID=your-feishu-app-id
# FEISHU_APP_SECRET=your-feishu-app-secret

# --- Slack ---
# SLACK_BOT_TOKEN=your-slack-bot-token    # xoxb-... 格式
# SLACK_APP_TOKEN=your-slack-app-token    # xapp-... 格式（Socket Mode）

# --- Telegram ---
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token


# ============================================================================
# 四、可观测性 / 调试追踪（LangSmith）
# ============================================================================
# 启用后可在 LangSmith 面板中监控 LLM 调用、Agent 运行和工具执行。
# 注册: https://smith.langchain.com

LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=scientific-tumbleweed


# ============================================================================
# 五、其他
# ============================================================================

# --- GitHub API Token（用于 Agent 访问 GitHub 仓库/Issue/PR）---
# GITHUB_TOKEN=your-github-token

# --- CORS 跨域白名单（逗号分隔，前端开发时可能需要）---
# CORS_ORIGINS=http://localhost:3000
